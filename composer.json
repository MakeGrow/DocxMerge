{
    "name": "mkgrow/docx-merge",
    "description": "Framework-agnostic DOCX document merging by markers.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.2",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "ext-xml": "*",
        "ext-zip": "*",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "DocxMerge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DocxMerge\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest --colors=always",
        "test:coverage": "pest --coverage --min=90",
        "analyse": "phpstan analyse --level=8 src/ tests/",
        "format": "php-cs-fixer fix",
        "format:check": "php-cs-fixer fix --dry-run --diff",
        "ci": [
            "@analyse",
            "@format:check",
            "@test:coverage"
        ]
    }
}
